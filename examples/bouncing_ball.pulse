patch bouncing_ball

generate clock metro
  every 1/4
end

generate pattern seed
  notes C3
end

project to_notes notes1
  scale C minor
  gate 85%
  velocity 104
end

transform bounce ball
  count 8
  spacing 180ms -> 25ms
  velocity 112 -> 36
end

output midi out
end

connect metro -> seed.trigger
connect seed -> notes1
connect notes1 -> ball
connect ball -> out
end
