patch chord_projector

clock metro
  every 1/16
end

pattern roots
  notes C3 E3 G3 B3 D4
end

lists lengths
  time 500ms
  gate 95%
end

notes harmony
  mode poly
  voices 5
  steal farthest_from_center
  center C4
  chord maj7
  scale C major
  range C2..C6
  velocity 104
end

midi out out
end

metro -> roots.trigger
roots -> harmony
lengths.time -> harmony.time
lengths.gate -> harmony.gate
harmony -> out
end
