patch contrary_projector

clock metro
  every 1/16
end

pattern roots
  notes C3 D3 E3 G3 A3
end

lists lengths
  time 420ms
  gate 95%
end

notes mover
  mode poly
  voices 6
  steal oldest
  chord major
  invert 1
  movement contrary
  keep bass
  avoid crossing
  scale C major
  range C2..C6
  velocity 100
end

midi out out
end

metro -> roots.trigger
roots -> mover
lengths.time -> mover.time
lengths.gate -> mover.gate
mover -> out
end
