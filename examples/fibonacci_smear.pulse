patch fibonacci_smear

clock metro
  every 1/16
end

fibonacci fib1
  length 8
  map 0 2 3 5 7
end

notes notes1
  scale D minor
  range C2..C5
  velocity 96
end

smear bergson
  keep 3
  weights 0.60 0.25 0.15
  drift weights 0.05
end

midi out out
end

metro -> fib1.trigger
fib1 -> notes1
notes1 -> bergson
bergson -> out
end
