patch interval_projector

clock metro
  every 1/16
end

pattern roots
  notes D3 F3 A3 C4
  order up_down
end

lists lengths
  time 450ms
  gate 95%
end

notes stacked
  mode poly
  voices 5
  steal quietest
  intervals 0 7 14
  scale D minor
  range C2..C6
  velocity 100
end

midi out out
end

metro -> roots.trigger
roots -> stacked
lengths.time -> stacked.time
lengths.gate -> stacked.gate
stacked -> out
end
