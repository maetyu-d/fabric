patch motion_to_notes

midi in keys
  channel 1
end

clock metro
  every 1/16
end

motion motion1
  channels 8
  space 0.4
  clocked on
end

notes notes1
  scale D minor
  range C2..C5
  velocity 100
end

midi out out
end

keys -> motion1
metro -> motion1.clock
motion1.speed -> notes1.values
motion1.even -> notes1.gate
notes1 -> out
end
