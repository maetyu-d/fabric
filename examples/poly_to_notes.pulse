patch poly_to_notes

clock metro
  every 1/16
end

pattern low
  notes C3 E3 G3 B3
end

pattern high
  notes E4 G4 B4 D5
end

lists lengths
  time 220ms 280ms
  gate 80% 90%
end

notes chordify
  mode poly
  voices 2
  steal oldest
  scale C major
  range C2..C6
  velocity 100
end

midi out out
end

metro -> low.trigger
metro -> high.trigger
low -> chordify
high -> chordify
lengths.time -> chordify.time
lengths.gate -> chordify.gate
chordify -> out
end
