patch random_machine

clock metro
  every 1/32
end

random chance1
  notes D3 F3 A3 C4 E4
  mode walk
  pass 70%
  avoid repeat
  max step 5
  bias center 0.8
  seed 42
end

notes notes1
  key D minor
  range C2..C5
  velocity 98
end

midi out out
end

metro -> chance1.trigger
chance1 -> notes1
notes1 -> out
end
