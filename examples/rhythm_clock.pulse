patch rhythm_clock

clock metro
  every 1/16
  groove shuffle
  tuplet 3:2
  ratchet 1 2 1 3
  chance 100%
  pulse chance 100%
  bars 4
  accents 1.0 0.7 0.85 0.7
end

pattern riff
  notes D3 F3 A3 C4
  order up_down
end

notes notes1
  quantize D dorian
  gate 56%
  velocity 88
end

midi out out
end

metro -> riff.trigger
riff -> notes1
notes1 -> out
end
