patch split_delay_arp

tempo 120
scale D minor

midi in keys
  channel 1
end

clock metro
  every 1/16
end

split bands
  by note
  low below C3
  mid C3..B4
  high above B4
end

delay low_late
  time 40ms
end

arp arp1
  gate 70%
end

midi out out
end

keys -> bands
bands.low -> low_late
bands.mid -> arp1
metro -> arp1.trigger
low_late -> out
arp1 -> out
bands.high -> out
end
