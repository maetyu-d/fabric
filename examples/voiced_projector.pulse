patch voiced_projector

clock metro
  every 1/16
end

pattern roots
  notes C3 D3 E3 G3 A3
end

lists lengths
  time 420ms
  gate 95%
end

notes voicer
  mode poly
  voices 6
  steal shortest_remaining
  center C4
  chord scale7
  invert 1
  drop 2
  spread 1 octave
  scale C major
  range C2..C6
  velocity 102
end

midi out out
end

metro -> roots.trigger
roots -> voicer
lengths.time -> voicer.time
lengths.gate -> voicer.gate
voicer -> out
end
