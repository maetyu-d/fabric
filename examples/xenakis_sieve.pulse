patch xenakis_sieve

clock metro
  every 1/16
end

pattern seq1
  notes C3 D3 Eb3 F3 F#3 G3 A3 Bb3
  order up_down
end

sieve mask1
  mod 12 keep 0 1 4 7
end

sieve rhythm1
  mod 8 keep 0 3 5
end

notes notes1
  quantize C major
  gate 60%
  velocity 100
end

midi out out
end

metro -> rhythm1.trigger
seq1 -> mask1
mask1 -> notes1
rhythm1.trigger -> notes1.gate
notes1 -> out
end
